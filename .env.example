# Supabase Configuration
EXPO_PUBLIC_SUPABASE_URL=your_supabase_url_here
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Mini Program Auth Configuration
# 登录会调用 ${EXPO_PUBLIC_SUPABASE_URL}/functions/v1/wechat-login

# AI API Configuration
# 支持 OpenAI 兼容接口（OpenAI、Azure OpenAI、国内大模型等）
EXPO_PUBLIC_AI_API_KEY=your_ai_api_key_here
EXPO_PUBLIC_AI_API_URL=https://api.openai.com/v1/chat/completions

# Mock Mode (开发环境建议设为 true，避免消耗 AI API 额度)
# true: 使用本地预设语录
# false: 调用真实 AI API
EXPO_PUBLIC_USE_MOCK=true
